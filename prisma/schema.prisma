generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────
// GAMES
// ─────────────────────────────────────────
model Game {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  igdb_id      Int?      @unique
  steam_appid  Int?      @unique
  cover_url    String
  screenshots  Json      @default("[]")
  platforms    Json      @default("[]")
  genres       Json      @default("[]")
  tags         Json      @default("[]")
  developer    String?
  publisher    String?
  release_date DateTime?

  score_opencritic   Float?
  score_steam_pct    Float?
  score_community    Float?
  score_review_count Int      @default(0)

  description   String?
  guide_count   Int      @default(0)
  code_count    Int      @default(0)
  video_count   Int      @default(0)
  has_tier_list Boolean  @default(false)
  last_patch_at DateTime?

  articles   Article[]
  codes      GameCode[]
  tier_lists TierList[]
  likes      Like[]
  favorites  Favorite[]
  videos     Video[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([slug])
  @@index([igdb_id])
}

// ─────────────────────────────────────────
// VIDEOS
// ─────────────────────────────────────────
model Video {
  id                String           @id @default(cuid())
  video_id          String
  platform          VideoPlatform
  game_id           String?
  game              Game?            @relation(fields: [game_id], references: [id])

  title             String
  description       String?
  thumbnail_url     String
  channel_name      String
  channel_url       String
  duration          Int?
  view_count        BigInt?
  like_count        BigInt?
  published_at      DateTime?

  video_type        VideoType        @default(GAMEPLAY)
  video_tags        Json             @default("[]")

  is_live           Boolean          @default(false)
  is_featured       Boolean          @default(false)
  is_active         Boolean          @default(true)

  // AI meta data
  ai_summary        String?
  ai_relevance_score Float?

  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  favorites         VideoFavorite[]
  likes             VideoLike[]
  comments          VideoComment[]
  view_history      VideoViewHistory[]

  @@unique([platform, video_id])
  @@index([game_id])
  @@index([platform])
  @@index([published_at])
  @@index([is_featured])
}

enum VideoPlatform {
  YOUTUBE
  TWITCH
  YOUTUBE_SHORTS
  TIKTOK
}

enum VideoType {
  GAMEPLAY
  TUTORIAL
  REVIEW
  WALKTHROUGH
  NEWS
  TRAILER
  LIVE
}

// ─────────────────────────────────────────
// ARTICLES
// ─────────────────────────────────────────
model Article {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  article_type ArticleType
  status       ArticleStatus @default(draft)
  source_type  SourceType    @default(ai)
  source_urls  Json          @default("[]")

  game_id String?
  game    Game?   @relation(fields: [game_id], references: [id])

  author_id String?
  author    User?   @relation(fields: [author_id], references: [id])

  cover_url    String
  cover_alt    String
  cover_credit String?
  content      String
  excerpt      String
  read_time    Int     @default(5)

  seo_title       String
  seo_description String
  seo_keywords    Json    @default("[]")
  canonical       String?

  affiliate_links Json   @default("[]")
  quality_score   Float?
  view_count      Int    @default(0)
  share_count     Int    @default(0)

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  comments Comment[]
  likes    Like[]

  @@index([slug])
  @@index([game_id])
  @@index([article_type])
  @@index([status])
  @@index([published_at])
}

enum ArticleType {
  guide
  news
  codes
  tierlist
  best
  patch_notes
}

enum ArticleStatus {
  draft
  review
  published
  archived
}

enum SourceType {
  ai
  ugc
  aggregated
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────
model User {
  id             String         @id @default(cuid())
  email          String         @unique
  username       String         @unique
  avatar         String?
  password_hash  String?
  membership     MembershipType @default(free)
  creator_level  CreatorLevel   @default(reader)
  points         Int            @default(0)
  earned_cents   Int            @default(0)
  pending_cents  Int            @default(0)
  total_views    Int            @default(0)
  article_count  Int            @default(0)
  preferred_games Json           @default("[]")

  articles           Article[]
  point_transactions PointTransaction[]
  tier_votes         TierVote[]
  code_submissions   GameCode[]
  video_favorites    VideoFavorite[]
  video_likes        VideoLike[]
  video_comments     VideoComment[]
  video_view_history VideoViewHistory[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([email])
  @@index([username])
}

enum MembershipType {
  free
  pro
  creator
}

enum CreatorLevel {
  reader
  creator
  verified
  partner
}

// ─────────────────────────────────────────
// GAME CODES
// ─────────────────────────────────────────
model GameCode {
  id          String     @id @default(cuid())
  code        String
  game_id     String
  game        Game       @relation(fields: [game_id], references: [id])
  reward_desc String
  status      CodeStatus @default(unverified)
  source      CodeSource
  source_url  String?
  expires_at  DateTime?
  verified_at DateTime   @default(now())

  submitted_by_id String?
  submitted_by    User?   @relation(fields: [submitted_by_id], references: [id])

  created_at DateTime @default(now())

  @@unique([code, game_id])
  @@index([game_id, status])
}

enum CodeStatus {
  active
  expired
  unverified
}

enum CodeSource {
  discord
  reddit
  official
  twitter
  user
}

// ─────────────────────────────────────────
// TIER LISTS
// ─────────────────────────────────────────
model TierList {
  id            String       @id @default(cuid())
  game_id       String
  game          Game         @relation(fields: [game_id], references: [id])
  category      TierCategory
  patch_version String
  is_community  Boolean      @default(true)
  total_votes   Int          @default(0)

  entries TierEntry[]
  votes   TierVote[]

  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  @@unique([game_id, category])
}

model TierEntry {
  id           String   @id @default(cuid())
  tier_list_id String
  tier_list    TierList @relation(fields: [tier_list_id], references: [id])
  name         String
  image_url    String
  grade        TierGrade
  vote_count   Int       @default(0)
  avg_score    Float     @default(3)
  description  String?

  votes TierVote[]

  @@index([tier_list_id])
}

model TierVote {
  id           String    @id @default(cuid())
  tier_list_id String
  tier_list    TierList  @relation(fields: [tier_list_id], references: [id])
  entry_id     String
  entry        TierEntry @relation(fields: [entry_id], references: [id])
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  grade        TierGrade
  created_at   DateTime  @default(now())

  @@unique([entry_id, user_id])
}

enum TierGrade {
  S
  A
  B
  C
  D
  F
}

enum TierCategory {
  character
  weapon
  class
  skill
  item
}

// ─────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────
model AffiliateClick {
  id         String   @id @default(cuid())
  partner    String
  article_id String?
  game_id    String?
  user_id    String?
  ip_hash    String
  created_at DateTime @default(now())

  @@index([partner])
  @@index([created_at])
}

enum PointTransactionType {
  earned
  spent
  bonus
}

enum PointReason {
  article_view
  code_use
  referral
  submission
  purchase
}

model PointTransaction {
  id         String               @id @default(cuid())
  user_id    String
  user       User                 @relation(fields: [user_id], references: [id])
  type       PointTransactionType
  amount     Int
  reason     PointReason
  created_at DateTime             @default(now())

  @@index([user_id])
}

// ─────────────────────────────────────────
// COMMENTS
// ─────────────────────────────────────────
model Comment {
  id             String   @id @default(cuid())
  article_slug   String
  article        Article  @relation(fields: [article_slug], references: [slug])
  author_username String
  author_avatar  String?
  content        String
  likes          Int      @default(0)
  parent_id      String?
  parent         Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies        Comment[] @relation("CommentReplies")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([article_slug])
  @@index([parent_id])
}

// ─────────────────────────────────────────
// LIKES / FAVORITES
// ─────────────────────────────────────────
model Like {
  id         String   @id @default(cuid())
  user_id    String
  article_id String?
  game_id    String?

  article    Article? @relation(fields: [article_id], references: [id])
  game       Game?    @relation(fields: [game_id], references: [id])
  
  created_at DateTime @default(now())

  @@unique([user_id, article_id])
  @@unique([user_id, game_id])
  @@index([user_id])
  @@index([article_id])
  @@index([game_id])
}

model Favorite {
  id         String   @id @default(cuid())
  user_id    String
  game_id    String
  game       Game      @relation(fields: [game_id], references: [id])
  created_at DateTime @default(now())

  @@unique([user_id, game_id])
  @@index([user_id])
  @@index([game_id])
}

// ─────────────────────────────────────────
// AI PLAYERS (AI仿真实玩家)
// ─────────────────────────────────────────
model AIPlayer {
  id             String     @id @default(cuid())
  username       String     @unique
  email          String     @unique
  avatar         String?
  age            Int?
  occupation     String?
  personality    Json       @default("{}")
  interests      Json       @default("[]")
  activity_level Float      @default(0.5)
  status         AIPlayerStatus @default(inactive)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  last_activity_at DateTime?
  total_posts    Int        @default(0)
  total_comments Int        @default(0)

  behavior_config AIBehaviorConfig?
  activity_logs   AIActivityLog[]
  stats           AIStats[]

  @@index([status])
  @@index([created_at])
}

enum AIPlayerStatus {
  active
  inactive
  paused
}

model AIBehaviorConfig {
  id                   String   @id @default(cuid())
  player_id            String   @unique
  player               AIPlayer @relation(fields: [player_id], references: [id], onDelete: Cascade)
  
  wake_up_time         String   @default("08:00")
  sleep_time           String   @default("23:00")
  activity_interval_min Int     @default(300)
  activity_interval_max Int     @default(1800)
  post_probability     Float    @default(0.1)
  comment_probability  Float    @default(0.3)
  reply_probability    Float    @default(0.5)
  typing_speed_min     Int      @default(30)
  typing_speed_max     Int      @default(60)
  thinking_time_min    Int      @default(2)
  thinking_time_max    Int      @default(10)
  
  updated_at           DateTime @updatedAt

  @@index([player_id])
}

model AIActivityLog {
  id            String          @id @default(cuid())
  player_id     String
  player        AIPlayer        @relation(fields: [player_id], references: [id], onDelete: Cascade)
  activity_type AIActivityType
  target_type   String
  target_id     String
  content       String?
  success       Boolean         @default(true)
  error_message String?
  
  created_at    DateTime        @default(now())

  @@index([player_id])
  @@index([activity_type])
  @@index([created_at])
}

enum AIActivityType {
  post
  comment
  reply
  like
  view
  share
}

model AIStats {
  id             String   @id @default(cuid())
  player_id      String
  player         AIPlayer @relation(fields: [player_id], references: [id], onDelete: Cascade)
  date           DateTime
  posts_count    Int      @default(0)
  comments_count Int      @default(0)
  replies_count  Int      @default(0)
  likes_count    Int      @default(0)
  active_minutes Int      @default(0)

  @@unique([player_id, date])
  @@index([player_id])
  @@index([date])
}

// ─────────────────────────────────────────
// ADMINISTRATION (管理员系统)
// ─────────────────────────────────────────
model AdminUser {
  id            String      @id @default(cuid())
  email         String      @unique
  username      String      @unique
  avatar        String?
  password_hash String
  role          AdminRoleType @default(editor)
  
  last_login_at DateTime?
  failed_attempts Int @default(0)
  locked_until   DateTime?
  
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  audit_logs AuditLog[]
  
  @@index([email])
  @@index([role])
}

enum AdminRoleType {
  super_admin
  admin
  moderator
  editor
}

model AdminRole {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  
  can_manage_users      Boolean @default(false)
  can_manage_games      Boolean @default(false)
  can_manage_articles   Boolean @default(false)
  can_manage_codes      Boolean @default(false)
  can_manage_tierlists  Boolean @default(false)
  can_manage_comments   Boolean @default(false)
  can_view_analytics    Boolean @default(false)
  can_manage_settings   Boolean @default(false)
  can_manage_roles      Boolean @default(false)
  can_manage_ai_players Boolean @default(false)
  
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
}

model AuditLog {
  id            String        @id @default(cuid())
  admin_id      String?
  admin         AdminUser?    @relation(fields: [admin_id], references: [id], onDelete: SetNull)
  
  action        AuditAction
  resource_type String
  resource_id   String?
  details       Json          @default("{}")
  ip_address    String?
  user_agent    String?
  success       Boolean       @default(true)
  error_message String?
  
  created_at    DateTime      @default(now())

  @@index([admin_id])
  @@index([action])
  @@index([resource_type])
  @@index([created_at])
}

enum AuditAction {
  login
  logout
  create
  update
  delete
  view
  export
  import
  backup
  restore
  settings_change
}

// ─────────────────────────────────────────
// 邮件订阅者
// ─────────────────────────────────────────
model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  status     String   @default("active") // active | unsubscribed
  games      String?  // JSON array of game slugs
  token      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([token])
}

// ─────────────────────────────────────────
// 系统设置
// ─────────────────────────────────────────
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  value_type  String   @default("string") // string | boolean | number | json
  description String?
  group       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([key])
  @@index([group])
}

// ─────────────────────────────────────────
// VIDEO INTERACTION (Phase 2)
// ─────────────────────────────────────────
model VideoFavorite {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video_id   String
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, video_id])
  @@index([user_id])
  @@index([video_id])
}

model VideoLike {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video_id   String
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, video_id])
  @@index([user_id])
  @@index([video_id])
}

model VideoComment {
  id         String          @id @default(cuid())
  video_id   String
  video      Video           @relation(fields: [video_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User            @relation(fields: [user_id], references: [id])
  content    String
  likes      Int             @default(0)
  parent_id  String?
  parent     VideoComment?   @relation("VideoCommentReplies", fields: [parent_id], references: [id])
  replies    VideoComment[]  @relation("VideoCommentReplies")
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@index([video_id])
  @@index([parent_id])
}

model VideoViewHistory {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video_id   String
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)
  watched_at DateTime @default(now())

  @@index([user_id, watched_at])
  @@index([video_id])
}


