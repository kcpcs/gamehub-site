# GameHub Environment Configuration
# Required for AI content generation

# ===================
# DATABASE
# ===================
DATABASE_URL="file:./dev.db"

# ===================
# REDIS (Optional)
# ===================
REDIS_URL="redis://localhost:6379"

# ===================
# AUTHENTICATION
# ===================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-change-in-production"

# ===================
# CLAUDE AI (Optional)
# ===================
# Get your API key from: https://console.anthropic.com/
#CLAUDE_API_KEY="sk-ant-your-api-key-here"

# ===================
# jiekou.ai (推荐 - 国内可访问)
# ===================
# Get your API key from: https://jiekou.ai/
JIEKOU_API_KEY="your-jiekou-api-key"
JIEKOU_API_URL="https://api.jiekou.ai/v1/chat/completions"

# ===================
# SITE CONFIGURATION
# ===================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===================
# MONITORING
# ===================
LOG_LEVEL="info"
ENABLE_PERFORMANCE_MONITORING="true"
ENABLE_ERROR_TRACKING="true"

# ===================
# ALERTS (Optional - for notifications)
# ===================
ALERT_EMAIL_ENABLED="false"
ALERT_EMAIL_RECIPIENTS=""
ALERT_SLACK_ENABLED="false"
ALERT_SLACK_WEBHOOK_URL=""
ALERT_DISCORD_ENABLED="false"
ALERT_DISCORD_WEBHOOK_URL=""
