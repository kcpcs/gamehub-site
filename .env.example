# ==============================================
# GameHub Environment Variables
# Complete reference for all environment variables
# Copy to .env.local (development) or .env.production (production)
# ==============================================

# ==============================================
# SECTION 1: REQUIRED VARIABLES (Must be set)
# ==============================================

# -------------------------------
# 1.1 Database Configuration
# -------------------------------
# Development: file:./dev.db
# Production (Turso): libsql://your-db.turso.io
DATABASE_URL="file:./dev.db"

# Turso authentication token (required for production remote database)
# Get from: https://app.turso.io
TURSO_AUTH_TOKEN=""

# -------------------------------
# 1.2 Authentication
# -------------------------------
# NextAuth secret key - generate with: openssl rand -base64 32
# REQUIRED in production - used for session encryption
NEXTAUTH_SECRET=""

# NextAuth URL - full URL of your site (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# Internal API secret for server-to-server authentication
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=""

# Admin API key for admin panel access
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=""

# ==============================================
# SECTION 2: PUBLIC VARIABLES (NEXT_PUBLIC_)
# These are exposed to the browser
# ==============================================

# -------------------------------
# 2.1 Site Configuration
# -------------------------------
# Public site URL (used for metadata, links, OpenGraph, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------
# 2.2 Third-party Services (Public)
# -------------------------------
# Algolia Search (public app ID - safe to expose)
NEXT_PUBLIC_ALGOLIA_APP_ID=""

# Google AdSense publisher ID (starts with ca-pub-)
NEXT_PUBLIC_ADSENSE_CLIENT=""

# ==============================================
# SECTION 3: SERVER-ONLY VARIABLES
# These are NEVER exposed to the browser
# ==============================================

# -------------------------------
# 3.1 OAuth Providers
# -------------------------------
# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -------------------------------
# 3.2 Search & Analytics
# -------------------------------
# Algolia (server-side admin key - NEVER expose to browser)
ALGOLIA_APP_ID=""
ALGOLIA_API_KEY=""
ALGOLIA_ADMIN_KEY=""

# -------------------------------
# 3.3 Caching (Upstash Redis)
# -------------------------------
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -------------------------------
# 3.4 Gaming Platform APIs
# -------------------------------
# YouTube Data API v3
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=""

# Twitch/IGDB API (used for game data)
# Get from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# IGDB API (alternative to Twitch - used for game data)
# Get from: https://api-docs.igdb.com/
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# TikTok API
# Get from: https://developers.tiktok.com/
TIKTOK_API_KEY=""

# Steam Web API
# Get from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# -------------------------------
# 3.5 AI & LLM Services
# -------------------------------
# Anthropic Claude API (for AI content generation)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Anthropic base URL (use Jiekou.ai proxy for China: https://api.jiekou.ai/anthropic)
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# Default Claude models
DEFAULT_CLAUDE_MODEL="claude-sonnet-4-6"
DEFAULT_OPUS_MODEL="claude-opus-4-7"
DEFAULT_HAIKU_MODEL="claude-haiku-4-5-20251001"

# OpenAI API (for additional AI features)
OPENAI_API_KEY=""

# Dify RAG API (for knowledge-based chat)
# Get from: https://dify.ai/
DIFY_API_KEY=""
DIFY_BASE_URL="https://api.dify.ai/v1"
DIFY_KNOWLEDGE_ID=""

# -------------------------------
# 3.6 Email Services
# -------------------------------
# Resend (recommended - https://resend.com)
RESEND_API_KEY=""

# Mailgun (alternative)
# Get from: https://app.mailgun.com/
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# ConvertKit (email marketing)
# Get from: https://app.convertkit.com/
CONVERTKIT_API_KEY=""
CONVERTKIT_FORM_ID=""

# ==============================================
# SECTION 4: OPTIONAL VARIABLES
# ==============================================

# -------------------------------
# 4.1 Logging & Monitoring
# -------------------------------
# Log level: debug | info | warn | error
LOG_LEVEL="info"

# Sentry DSN for error tracking
# Get from: https://sentry.io/
SENTRY_DSN=""

# -------------------------------
# 4.2 Alerting & Notifications
# -------------------------------
# Email alerts
ALERT_EMAIL_ENABLED="false"
ALERT_EMAIL_RECIPIENTS="admin@example.com,oncall@example.com"

# Slack alerts
ALERT_SLACK_ENABLED="false"
ALERT_SLACK_WEBHOOK_URL=""

# Discord alerts
ALERT_DISCORD_ENABLED="false"
ALERT_DISCORD_WEBHOOK_URL=""

# ==============================================
# SECTION 5: NODE ENVIRONMENT
# ==============================================
# Do NOT set manually - automatically set by Next.js
# NODE_ENV=development | production | test

# ==============================================
# SECTION 6: PRODUCTION NOTES
# ==============================================
# For production deployment:
# 1. Copy this file to .env.production
# 2. Fill in all REQUIRED variables
# 3. Set NEXTAUTH_URL to your production domain
# 4. Use Turso remote database (libsql://...)
# 5. Generate new NEXTAUTH_SECRET and INTERNAL_API_SECRET
# 6. Configure OAuth providers with production callbacks
