# GameHub AI自动化工作流 - 配置文件
# 复制为 .env.ai 并填写真实值

# Claude AI配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI工作流配置
AI_WORKFLOW_ENABLED=true
AI_CONTENT_GENERATION=true
AI_AUTO_PUBLISH=false

# 频率配置 (cron格式)
CRON_CONTENT_MONITOR=0 */6 * * *       # 每6小时
CRON_CODE_CHECKER=0 0 * * *           # 每天
CRON_GAME_UPDATER=0 0 */3 * *         # 每3天
CRON_CONTENT_GENERATOR=0 0 * * 0       # 每周日

# 日志级别 (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# 数据库配置 (继承主项目配置)
DATABASE_URL=file:./dev.db

# 通知配置 (可选)
NOTIFICATION_EMAIL=your_email@example.com
NOTIFICATION_DISCORD_WEBHOOK=
NOTIFICATION_SLACK_WEBHOOK=

# 内容生成配置
MAX_CONTENT_PER_RUN=5
GUIDE_WORD_COUNT=1500
ENABLE_AUTO_PUBLISH=false
