# TRAE 忽略文件配置
# 本文件定义了 AI 在工作时应该忽略的目录和文件
# 这有助于提升理解准确性、减少幻觉、加快分析速度

# ==================== 依赖目录 ====================
# 这些目录包含大量第三方代码，不需要 AI 理解和分析
node_modules/
.vendor/
vendor/bundle/
packages/*/node_modules/

# ==================== 构建输出 ====================
# 构建产物不需要分析
dist/
.build/
.next/
.nuxt/
out/
build/
target/

# ==================== 缓存目录 ====================
# 缓存文件不需要分析
.cache/
.turbo/
.npm/
.yarn/
pnpm-store/

# ==================== Git 目录 ====================
# Git 相关文件不需要分析
.git/
.gitignore
.gitattributes

# ==================== 环境配置 ====================
# 环境变量文件包含敏感信息，不需要分析
.env
.env.*
!.env.example
!.env.ai.example

# ==================== IDE 配置 ====================
# IDE 配置文件不需要分析
.idea/
.vscode/
*.swp
*.swo
*~

# ==================== 日志文件 ====================
# 日志文件不需要分析
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 临时文件 ====================
# 临时文件不需要分析
.tmp/
tmp/
temp/
*.tmp

# ==================== 数据库文件 ====================
# 开发数据库文件不需要分析
*.db
*.sqlite
*.sqlite3

# ==================== 测试覆盖率 ====================
# 测试覆盖率报告不需要分析
coverage/
.nyc_output/

# ==================== 文档目录 ====================
# 项目根目录的文档文件不需要分析
*.md
!README.md
!AGENTS.md
!CLAUDE.md

# ==================== 备份文件 ====================
# 备份文件不需要分析
*.bak
*.backup
*.back

# ==================== 特殊文件 ====================
.DS_Store
Thumbs.db
desktop.ini

# ==================== 工作流配置 ====================
# CI/CD 配置不需要在日常开发中分析
.github/
.gitlab-ci.yml
.circleci/

# ==================== 规则目录 ====================
# 规则目录由系统管理，不需要分析
.trae/rules/
!.trae/rules/*.md
