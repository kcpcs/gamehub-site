# ==============================================
# GameHub Production Environment Variables
# ==============================================

# ------------------------------
# Basic Configuration
# ------------------------------
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com
LOG_LEVEL=info

# ------------------------------
# Database Configuration (Turso)
# ------------------------------
DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ------------------------------
# NextAuth Configuration
# ------------------------------
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate-a-secure-secret-here-32-characters-minimum
INTERNAL_API_SECRET=generate-internal-api-secret-here
ADMIN_API_KEY=generate-admin-api-key-here

# ------------------------------
# OAuth Providers
# ------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-secret

# ------------------------------
# Redis Cache (Upstash)
# ------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ------------------------------
# Algolia Search
# ------------------------------
NEXT_PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_ADMIN_KEY=your-algolia-admin-key
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your-algolia-search-key

# ------------------------------
# AI/LLM Configuration
# ------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.jiekou.ai/anthropic
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEFAULT_OPUS_MODEL=claude-3-opus-20240229
DEFAULT_HAIKU_MODEL=claude-3-haiku-20240307

# Optional: OpenAI
OPENAI_API_KEY=your-openai-api-key

# Optional: Dify
DIFY_API_KEY=your-dify-api-key
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_KNOWLEDGE_ID=your-dify-knowledge-id

# ------------------------------
# External APIs
# ------------------------------
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
STEAM_API_KEY=your-steam-api-key
YOUTUBE_API_KEY=your-youtube-api-key
TIKTOK_API_KEY=your-tiktok-api-key

# ------------------------------
# Email Services
# ------------------------------
RESEND_API_KEY=your-resend-api-key
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
CONVERTKIT_API_KEY=your-convertkit-api-key
CONVERTKIT_FORM_ID=your-convertkit-form-id

# ------------------------------
# Advertising
# ------------------------------
NEXT_PUBLIC_ADSENSE_CLIENT=your-adsense-client-id

# ------------------------------
# Monitoring & Analytics
# ------------------------------
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=your-google-analytics-id

# ------------------------------
# Alerting Configuration
# ------------------------------
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENTS=your@email.com
ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK_URL=your-slack-webhook-url
ALERT_DISCORD_ENABLED=false
ALERT_DISCORD_WEBHOOK_URL=your-discord-webhook-url

# ------------------------------
# Stripe (for subscriptions)
# ------------------------------
STRIPE_API_KEY=your-stripe-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ------------------------------
# Feature Flags
# ------------------------------
FEATURE_AI_PLAYERS_ENABLED=true
FEATURE_CREATOR_PROGRAM_ENABLED=true
FEATURE_TIER_LISTS_ENABLED=true
FEATURE_VIDEO_SECTION_ENABLED=true